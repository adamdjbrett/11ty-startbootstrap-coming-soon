<!DOCTYPE html>
<html lang="{{ metadata.language | default('en') }}" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="{{ metadata.description }}" />
    <meta name="author" content="{{ metadata.author }}" />
    <meta name="theme-color" content="{{ metadata.theme_color }}" />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content="{{ title or metadata.title }}" />
    <meta property="og:description" content="{{ metadata.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ page.url | toAbsoluteUrl(metadata.url) }}" />
    <meta property="og:image" content="{{ metadata.hero_image_webp | toAbsoluteUrl(metadata.url) }}" />
    <link rel="canonical" href="{{ page.url | toAbsoluteUrl(metadata.url) }}" />
    <title>{{ title or metadata.title }}</title>
    <link rel="icon" type="image/x-icon" href="{{ metadata.favicon }}" />
    <link rel="preload" href="/css/styles.css" as="style" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
      html,
      body {
        height: 100%;
      }
      body {
        margin: 0;
        position: relative;
        background: {{ metadata.theme_color }};
        color: #fff;
      }
      .masthead {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
      }
      .masthead-content {
        max-width: 40rem;
        padding: 5rem 1.5rem;
      }
      .skip-link {
        position: absolute;
        left: 0.5rem;
        top: 0.5rem;
        z-index: 4;
        transform: translateY(-140%);
        background: #fff;
        color: #000;
        padding: 0.5rem 0.75rem;
        border-radius: 0.25rem;
        text-decoration: none;
      }
      .skip-link:focus {
        transform: translateY(0);
      }
      .site-footer {
        position: relative;
        z-index: 3;
        text-align: center;
        padding: 1rem;
      }
    </style>
    <script>
      document.documentElement.classList.remove("no-js");
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    {{ content | safe }}
    <footer class="site-footer">
      <p>
        &copy; {{ "" | currentYear }} {{ metadata.copyright_holder }}.
        Built with <a href="https://11ty.dev" rel="noopener">11ty</a>.
      </p>
    </footer>
    <script src="/js/scripts.js"></script>
  </body>
</html>
