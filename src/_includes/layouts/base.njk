<!DOCTYPE html>
<html lang="{{ metadata.language | default('en') }}" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="{{ metadata.description }}" />
    <meta name="author" content="{{ metadata.author }}" />
    <meta name="theme-color" content="{{ metadata.theme_color }}" />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content="{{ title or metadata.title }}" />
    <meta property="og:description" content="{{ metadata.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ page.url | toAbsoluteUrl(metadata.url) }}" />
    <meta property="og:image" content="{{ metadata.hero_image_webp | toAbsoluteUrl(metadata.url) }}" />
    <link rel="canonical" href="{{ page.url | toAbsoluteUrl(metadata.url) }}" />
    <title>{{ title or metadata.title }}</title>
    <link rel="icon" type="image/x-icon" href="{{ metadata.favicon }}" />
    <link rel="preload" href="/css/styles.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="/css/styles.css" /></noscript>
    <link rel="preload" href="/assets/css/deferred.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="/assets/css/deferred.css" /></noscript>
    <style>
      html,
      body {
        height: 100%;
        margin: 0;
        overflow: hidden;
      }
      body {
        position: relative;
        display: flex;
        flex-direction: column;
        background: {{ metadata.theme_color }};
        color: #fff;
      }
      .masthead {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100dvh;
        width: min(75vw, 100%);
        padding-bottom: 4.25rem;
      }
      .masthead-content {
        width: 100%;
        max-width: 40rem;
      }
      .masthead-inner {
        padding: clamp(1.25rem, 3.5vh, 2.25rem) clamp(1rem, 3vw, 2rem);
      }
      .masthead-title {
        margin: 0 0 1rem;
        font-size: clamp(1.8rem, 4.8vw, 3.2rem);
        line-height: 1;
        font-style: italic;
      }
      .masthead-lead {
        margin: 0 0 1.25rem;
        font-size: clamp(1rem, 2.2vw, 1.2rem);
      }
      .input-group-newsletter {
        display: flex;
        gap: 0.5rem;
      }
      .newsletter-input {
        width: 100%;
        min-width: 0;
        padding: 0.9rem 1rem;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
      }
      .newsletter-button {
        padding: 0.9rem 1rem;
        border: 1px solid #0d6efd;
        border-radius: 0.375rem;
        background: #0d6efd;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 700;
        white-space: nowrap;
      }
      .skip-link {
        position: absolute;
        left: 0.5rem;
        top: 0.5rem;
        z-index: 4;
        transform: translateY(-140%);
        background: #fff;
        color: #000;
        padding: 0.5rem 0.75rem;
        border-radius: 0.25rem;
        text-decoration: none;
      }
      .skip-link:focus {
        transform: translateY(0);
      }
      .social-icons {
        position: relative;
        z-index: 3;
      }
      .social-icons-inner {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .social-link {
        display: inline-flex;
        width: 3.3rem;
        height: 3.3rem;
        margin: 0.5rem;
        border-radius: 999px;
        background: #212529;
        color: #fff;
        align-items: center;
        justify-content: center;
        text-decoration: none;
      }
      .social-icon-svg {
        width: 1.3rem;
        height: 1.3rem;
      }
      .site-footer {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 3;
        text-align: center;
        padding: 0.75rem 1rem;
      }
      .site-footer p {
        margin: 0;
      }
      .site-footer a {
        color: #fff;
      }
      @media (max-width: 991px) {
        .masthead {
          width: 100%;
          padding-bottom: 7rem;
        }
      }
      @media (max-width: 575px) {
        .input-group-newsletter {
          flex-direction: column;
        }
      }
      @media (min-width: 992px) {
        .social-icons {
          position: absolute;
          top: 0;
          right: 2.5rem;
          height: 100%;
        }
        .social-icons-inner {
          flex-direction: column;
          height: 100%;
          justify-content: center;
        }
      }
    </style>
    <script>
      document.documentElement.classList.remove("no-js");
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    {{ content | safe }}
    <footer class="site-footer">
      <p>
        &copy; {{ "" | currentYear }} {{ metadata.copyright_holder }}.
        Built with <a href="https://11ty.dev" rel="noopener">11ty</a>.
      </p>
    </footer>
    <script src="/js/scripts.js"></script>
  </body>
</html>
