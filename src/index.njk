---
layout: layouts/base.njk
---
<video
  class="bg-video"
  id="bg-video"
  playsinline
  muted
  loop
  preload="none"
  poster="{{ metadata.hero_image_webp }}"
  aria-hidden="true"
>
  <source data-src="{{ metadata.hero_video_mp4 }}" type="video/mp4" />
</video>

<main id="main-content" class="masthead" tabindex="-1">
  <section class="masthead-content text-white" aria-labelledby="coming-soon-title">
    <div class="container-fluid px-4 px-lg-0">
      <h1 id="coming-soon-title" class="fst-italic lh-1 mb-4">{{ metadata.hero_heading }}</h1>
      <p class="mb-5">{{ metadata.hero_message }}</p>

      <form id="contactForm" action="https://formspree.io/f/{{ metadata.formspree_key }}" method="POST" novalidate>
        <div class="row input-group-newsletter" role="group" aria-labelledby="email-label">
          <div class="col">
            <label class="visually-hidden" id="email-label" for="email">Email address</label>
            <input
              class="form-control"
              id="email"
              type="email"
              name="email"
              placeholder="Enter email address..."
              autocomplete="email"
              required
            />
          </div>
          <div class="col-auto">
            <button class="btn btn-primary" id="submitButton" type="submit">{{ metadata.form_submit_label }}</button>
          </div>
        </div>
      </form>
    </div>
  </section>
</main>

<nav class="social-icons" aria-label="Social media links">
  <div class="d-flex flex-row flex-lg-column justify-content-center align-items-center h-100 mt-3 mt-lg-0">
    {% for social in metadata.social_links %}
      <a class="btn btn-dark m-3" href="{{ social.url }}" aria-label="{{ social.name }}">
        {% if social.name == "Twitter" %}
          <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false" class="social-icon-svg">
            <path fill="currentColor" d="M23 3.01a9.14 9.14 0 0 1-2.64.77 4.57 4.57 0 0 0 2.01-2.52 9.02 9.02 0 0 1-2.9 1.13 4.52 4.52 0 0 0-7.79 3.1c0 .36.04.72.12 1.06A12.83 12.83 0 0 1 2.25 2.2a4.54 4.54 0 0 0 1.4 6.06 4.45 4.45 0 0 1-2.04-.58v.06c0 2.2 1.55 4.03 3.6 4.45a4.45 4.45 0 0 1-2.03.08 4.52 4.52 0 0 0 4.22 3.15A9.06 9.06 0 0 1 1 17.28a12.77 12.77 0 0 0 6.92 2.03c8.3 0 12.84-6.98 12.84-13.02l-.01-.59A9.25 9.25 0 0 0 23 3.01z"/>
          </svg>
        {% elif social.name == "Facebook" %}
          <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false" class="social-icon-svg">
            <path fill="currentColor" d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/>
          </svg>
        {% elif social.name == "Instagram" %}
          <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false" class="social-icon-svg">
            <path fill="currentColor" d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm-.2 2A3.55 3.55 0 0 0 4 7.55v8.9A3.55 3.55 0 0 0 7.55 20h8.9A3.55 3.55 0 0 0 20 16.45v-8.9A3.55 3.55 0 0 0 16.45 4h-8.9zM12 7.25A4.75 4.75 0 1 1 7.25 12 4.75 4.75 0 0 1 12 7.25zm0 2A2.75 2.75 0 1 0 14.75 12 2.75 2.75 0 0 0 12 9.25zm4.95-2.65a1.15 1.15 0 1 1-1.15 1.15 1.15 1.15 0 0 1 1.15-1.15z"/>
          </svg>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</nav>
